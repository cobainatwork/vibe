# Server
GATEWAY_PORT=8000

# Limits
MAX_FILE_SIZE_MB=1024
QUEUE_MAX_DEPTH=100
WS_IDLE_TIMEOUT_SEC=60

# Retention (days)
RETAIN_UPLOAD_DAYS=0
RETAIN_RESULT_DAYS=30
RETAIN_JOB_RECORD_DAYS=90

# Paths (inside container)
UPLOAD_DIR=/app/data/uploads
RESULT_DIR=/app/data/results
DB_PATH=/app/data/db/vibevoice.db
API_KEYS_PATH=/app/config/api_keys.yaml

# Services
REDIS_URL=redis://redis:6379/0
VLLM_URL=http://vllm:8001

# vLLM (host-side)
VLLM_TP=1
VLLM_DP=1
